# ── Stage 1: Rust build base ──────────────────────────────────────────────────
# Shared base for builder and dev targets. Contains the full Rust toolchain
# plus C++ deps required to compile the aribcaption-sys vendor submodule.
FROM rust:1-slim-bookworm AS builder-base
ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    ca-certificates pkg-config libssl-dev \
    cmake clang libclang-dev g++ \
    libfreetype6-dev libfontconfig1-dev \
    && rm -rf /var/lib/apt/lists/*

# ── Stage 2: Release binary ───────────────────────────────────────────────────
FROM builder-base AS builder

WORKDIR /app
# Copy only source files needed for the build.
# config.toml is intentionally excluded (see .dockerignore) so that editing it
# does not invalidate the cargo build cache layer.
COPY Cargo.toml Cargo.lock askama.toml ./
COPY src/ ./src/
# crates/ includes aribcaption-sys/vendor/libaribcaption (C source, submodule).
# Do not drop crates/ from this list — it is needed at cmake build time.
COPY crates/ ./crates/
COPY migrations/ ./migrations/
# .sqlx/ contains the offline query cache generated by `scripts/prepare.sh`.
# SQLX_OFFLINE=true lets cargo build without a live database.
COPY .sqlx/ ./.sqlx/
COPY ui/ ./ui/
ENV SQLX_OFFLINE=true
RUN cargo build --release --bin captu

# ── Stage 3: Development shell ────────────────────────────────────────────────
# Used by scripts/dev.sh: docker build --target dev -f Dockerfile .
# Extends builder-base with runtime tools (ffmpeg, sqlite3) and the ARIB font.
FROM builder-base AS dev
ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    ffmpeg sqlite3 curl \
    && rm -rf /var/lib/apt/lists/*

# Install Rust components needed for development verification (fmt, clippy).
RUN rustup component add rustfmt clippy

# Coverage: nightly is used only for `cargo llvm-cov`; normal build/test stay stable.
# coverage_attribute (#[coverage(off)]) is not yet stable as of rust:1.
RUN rustup toolchain install nightly --component llvm-tools-preview
ARG TARGETARCH
RUN case "${TARGETARCH}" in \
      amd64) LLVM_COV_ARCH=x86_64-unknown-linux-gnu ;; \
      arm64) LLVM_COV_ARCH=aarch64-unknown-linux-gnu ;; \
      *) echo "unsupported TARGETARCH: ${TARGETARCH}" >&2; exit 1 ;; \
    esac && \
    curl -LsSf \
      "https://github.com/taiki-e/cargo-llvm-cov/releases/latest/download/cargo-llvm-cov-${LLVM_COV_ARCH}.tar.gz" \
      | tar xzf - -C /usr/local/cargo/bin

# Rounded M+ 1m for ARIB subtitle rendering (same font as runtime image)
COPY docker/assets/fonts/rounded-mplus-1m-arib.ttf /usr/local/share/fonts/
COPY docker/assets/fonts/99-captu-fonts.conf /etc/fonts/conf.d/
RUN fc-cache -f

WORKDIR /app

# ── Stage 4: Production runtime ───────────────────────────────────────────────
# debian:bookworm-slim — stock ffmpeg from apt handles TS decode, deinterlace,
# scale, and JPEG output. No custom build needed; ARIB caption decode/render is
# done entirely by the Rust binary (aribcaption-sys static link).
FROM debian:bookworm-slim AS runtime
ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    ca-certificates \
    ffmpeg \
    fontconfig libfreetype6 \
    && rm -rf /var/lib/apt/lists/*

# Rounded M+ 1m for ARIB subtitle burn-in via fontconfig + freetype.
# fontconfig alias maps sans-serif → Rounded M+ 1m for ARIB so aribcaption-sys
# renders with the ARIB-optimised rounded gothic typeface.
COPY docker/assets/fonts/rounded-mplus-1m-arib.ttf /usr/local/share/fonts/
COPY docker/assets/fonts/99-captu-fonts.conf /etc/fonts/conf.d/
RUN fc-cache -f

COPY --from=builder /app/target/release/captu /usr/local/bin/captu
# ui/static/ is served relative to WORKDIR via ServeDir::new("ui/static")
COPY ui/static/ /app/ui/static/

WORKDIR /app
ENV TZ=Asia/Tokyo
CMD ["/usr/local/bin/captu"]
