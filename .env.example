# Copy to .env and fill in your values.
# docker compose reads .env automatically.

# Host path to the recordings directory (mounted read-only inside the container).
CAPTU_NAS_HOST=/mnt/your/recordings

# Host user/group that owns the bind-mounted data/ and cache/ dirs.
# Default 1000:1000. Set to `id -u`/`id -g` if your host user differs.
CAPTU_UID=1000
CAPTU_GID=1000

# Host port to publish the web UI on (container always listens on 8000).
CAPTU_PORT=8000
